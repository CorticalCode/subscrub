{
  "version": "2026.03",
  "description": "Sindarin and Quenya language filter patterns",
  "filters": [
    "/^teithant\\s*[:]/",
    "/^teithanner\\s*[:]/",
    "/^pennas\\s*[:]/",
    "/^peniath\\s*[:]/",
    "/^prestannen\\s*[:]/",
    "/^teitho\\s*(an|na|:)/",
    "/^quettar\\s*[:]/",
    "/^quenta\\s*[:]/",
    "/^tecil\\s*[:]/",
    "/^tengwar\\s*[:]/",
    "/^ash nazg/",
    "/^agh burzum/",
